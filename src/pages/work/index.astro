---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";
import { WORK, type WorkItem } from "../../data/work";
import { REVEAL_FLAGGED } from "../../config";

// Flagged/unannounced items live ONLY in a gitignored sibling (work.secret.ts),
// so they never enter the public repo. import.meta.glob resolves to {} when the
// file is absent (e.g. a public CI checkout), so the build always succeeds.
const secretMods = import.meta.glob<{ SECRET_WORK?: WorkItem[] }>(
  "../../data/work.secret.ts",
  { eager: true },
);
const secretWork = Object.values(secretMods).flatMap((m) => m.SECRET_WORK ?? []);

// Public filter: shown publicly AND (not flagged OR the reveal flag is on).
// REVEAL_FLAGGED defaults to false, so flagged items never render publicly.
const items = [...WORK, ...secretWork].filter(
  (w) => w.public && (!w.flagged || REVEAL_FLAGGED),
);
---

<BaseLayout
  title="Work"
  description="Open-source software, books, and tools — Bayesian computation and probabilistic programming."
>
  <section class="container section">
    <header class="work-intro flow">
      <p class="eyebrow">Work</p>
      <h1>Software, books &amp; tools</h1>
      <p class="muted work-intro__lede">
        Open-source projects and writing in Bayesian computation and
        probabilistic programming — most of it built in the open.
      </p>
    </header>

    <hr class="rule" />

    <ul class="work-grid" role="list">
      {
        items.map((item) => (
          <li>
            <WorkCard item={item} />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .work-intro__lede {
    max-width: var(--measure);
    font-size: var(--step-1);
  }
  .work-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-l);
    grid-template-columns: 1fr;
  }
  .work-grid > li {
    display: flex;
  }
  .work-grid > li > * {
    width: 100%;
  }
  @media (min-width: 40rem) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
