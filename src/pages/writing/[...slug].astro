---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import DocMeta from "../../components/prose/DocMeta.astro";
import Toc from "../../components/prose/Toc.astro";
import Comments from "../../components/prose/Comments.astro";
import Figure from "../../components/prose/Figure.astro";
import Sidenote from "../../components/prose/Sidenote.astro";
import { SITE } from "../../config";

// Drafts ARE built in production but UNLISTED: reachable by direct URL (for
// sharing/preview), kept off the writing list, marked noindex, and excluded from
// the sitemap (see astro.config.mjs). Unfinished is not the same as secret —
// confidential content uses *.secret.ts / REVEAL_FLAGGED, never a draft, and the
// deploy confidentiality gate scans the whole build regardless.
export async function getStaticPaths() {
  const posts = await getCollection("writing");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"writing"> };
const { post } = Astro.props;
const { Content, headings } = await post.render();

const isDraft = post.data.status === "draft";
const updated = post.data.updated ?? post.data.date;

// Article JSON-LD (public-safe: title/description/dates/author only).
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString().slice(0, 10),
  dateModified: updated.toISOString().slice(0, 10),
  author: { "@type": "Person", name: SITE.name, url: SITE.url },
  url: new URL(`/writing/${post.slug}/`, SITE.url).href,
  inLanguage: SITE.locale,
};
---

<BaseLayout title={post.data.title} description={post.data.description} ogType="article">
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    <meta property="article:modified_time" content={updated.toISOString()} />
    {post.data.tags.map((t) => <meta property="article:tag" content={t} />)}
    {/* Drafts are noindex: reachable by direct URL, kept out of search. */}
    {isDraft && <meta name="robots" content="noindex, nofollow" />}
    {/* Only emit JSON-LD for non-draft (public) posts. */}
    {!isDraft && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </Fragment>

  <article class="container section post">
    <header class="post__header">
      {isDraft && (
        <p class="post__draft-banner" role="status">
          This is a <strong>draft</strong> — a work in progress, not yet listed publicly.
          Expect rough edges and revisions.
        </p>
      )}
      <h1 class="post__title">{post.data.title}</h1>
      {post.data.description && (
        <p class="post__lede muted">{post.data.description}</p>
      )}
      <DocMeta
        status={post.data.status}
        date={post.data.date}
        updated={post.data.updated}
      />
      {post.data.tags.length > 0 && (
        <ul class="post__tags" aria-label="Tags">
          {post.data.tags.map((t) => (
            <li class="tag">{t}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="post__toc">
      <Toc headings={headings} />
    </div>

    <div class="post__body prose">
      <Content components={{ Figure, Sidenote }} />
    </div>

    <div class="post__comments">
      <Comments />
    </div>
  </article>

  <style>
    .post {
      max-width: 52rem;
    }

    /* Wide screens: the table of contents becomes a sticky left rail that rides
       along as you scroll; header + body + comments sit in the right column.
       Below 64rem it falls back to the inline "On this page" band up top. */
    @media (min-width: 64rem) {
      .post {
        max-width: 58rem;
        display: grid;
        grid-template-columns: 11rem minmax(0, 1fr);
        column-gap: var(--space-l);
        grid-template-areas:
          "toc header"
          "toc body"
          "toc comments";
      }
      .post__header {
        grid-area: header;
      }
      .post__toc {
        grid-area: toc;
      }
      .post__body {
        grid-area: body;
      }
      .post__comments {
        grid-area: comments;
      }
      /* :global reaches the Toc component's scoped <nav class="toc">. In the rail
         we drop the top/bottom band and let it stick. */
      .post__toc :global(.toc) {
        position: sticky;
        top: var(--space-xl);
        margin: 0;
        padding: 0;
        border: 0;
      }
    }

    .post__header {
      margin-bottom: var(--space-xl);
    }
    .post__draft-banner {
      font-size: var(--step--1);
      color: var(--muted);
      border-left: 2px solid var(--accent);
      padding: var(--space-s) var(--space-m);
      background: rgba(0, 0, 0, 0.02);
      border-radius: 0 4px 4px 0;
      margin-bottom: var(--space-l);
    }
    .post__title {
      margin-bottom: var(--space-s);
    }
    .post__lede {
      font-size: var(--step-1);
      line-height: 1.4;
      max-width: var(--measure);
      margin-bottom: var(--space-m);
    }
    .post__tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-m);
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .post__tags .tag {
      text-transform: none;
      letter-spacing: 0;
    }
    /* Body prose is constrained but the right margin is left open so wide-screen
       sidenotes (see Sidenote.astro) can float into it. */
    .post__body {
      max-width: var(--measure);
    }

    /* Figures authored in markdown (raw <figure class="fig">). Self-hosted
       images + a caption that credits/links the original source — the site's
       no-embed convention. Uses :global because markdown HTML is not scoped. */
    .post__body :global(.fig) {
      margin: var(--space-xl) 0;
    }
    .post__body :global(.fig img),
    .post__body :global(.fig video) {
      max-width: 100%;
      height: auto;
      border: 1px solid var(--rule);
      border-radius: 4px;
      background: #fff;
    }
    .post__body :global(.fig figcaption) {
      margin-top: var(--space-s);
      font-size: var(--step--1);
      color: var(--muted);
      line-height: 1.5;
    }

    /* Looping meme video with the caption overlaid, centered on the frame. */
    .post__body :global(.fig--loop) {
      position: relative;
      display: inline-block;
      max-width: 100%;
    }
    .post__body :global(.fig--loop video) {
      display: block;
    }
    .post__body :global(.fig--loop .fig__overlay) {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 8%; /* sit near the bottom, like a subtitle */
      margin: 0;
      padding: 0 var(--space-l);
      text-align: center;
      line-height: 1.3;
      font-style: italic;
      font-size: var(--step-1);
      color: #fff;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.75);
      pointer-events: none;
    }
  </style>
</BaseLayout>
