---
import type { WorkItem } from "../data/work";

interface Props {
  item: WorkItem;
}

const { item } = Astro.props;
---

<article class="card flow">
  <p class="eyebrow card__role">{item.role}</p>
  <h2 class="card__title">{item.title}</h2>
  <p class="card__blurb">{item.blurb}</p>

  {
    item.tags.length > 0 && (
      <ul class="card__tags" aria-label="Tags">
        {item.tags.map((t) => (
          <li class="tag">{t}</li>
        ))}
      </ul>
    )
  }

  {
    item.links.length > 0 && (
      <ul class="card__links" aria-label={`Links for ${item.title}`}>
        {item.links.map((l) => (
          <li>
            <a href={l.href} rel="noopener">
              {l.label} <span aria-hidden="true">-&gt;</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-l);
    border: 1px solid var(--rule);
    border-top: 2px solid var(--accent);
    background: var(--bg);
  }
  .card__role {
    margin: 0;
  }
  .card__title {
    font-size: var(--step-1);
    margin: 0;
  }
  .card__blurb {
    color: var(--muted);
    margin: 0;
    max-width: var(--measure);
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s) var(--space-m);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* Push links to the bottom so cards in a row align cleanly. */
  .card__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    list-style: none;
    margin: 0;
    padding: 0;
    margin-top: auto;
    padding-top: var(--space-s);
    font-weight: 500;
  }
</style>
